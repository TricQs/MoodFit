        target_content: "fun getMoodGradientBrush(mood: String, isDark: Boolean): Brush {\n    return when (mood.lowercase()) {\n        \"happy\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF332000), Color(0xFF191000)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFFFF7ED), Color(0xFFFFEDD5)))\n            }\n        }\n        \"stressed\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF00221E), Color(0xFF00110F)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFF0FDF4), Color(0xFFDCFCE7)))\n            }\n        }\n        \"tired\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF1B1437), Color(0xFF0C091C)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFFAFAFF), Color(0xFFEEF2FF)))\n            }\n        }\n        \"productive\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF00253F), Color(0xFF00111E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFEFF6FF), Color(0xFFDBEAFE)))\n            }\n        }\n        \"bored\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF1F2937), Color(0xFF111827)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFF9FAFB), Color(0xFFF3F4F6)))\n            }\n        }\n        else -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF1F2937), Color(0xFF111827)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFFFFFFF), Color(0xFFF3F4F6)))\n            }\n        }\n    }\n}"
        replacement_content: "fun getMoodGradientBrush(mood: String, isDark: Boolean): Brush {\n    return when (mood.lowercase()) {\n        \"happy\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF2C1E08), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFFFF4D4), Color(0xFFEADDFF)))\n            }\n        }\n        \"stressed\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF092518), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFE2F9EE), Color(0xFFEADDFF)))\n            }\n        }\n        \"tired\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF14122A), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFE9E5FF), Color(0xFFEADDFF)))\n            }\n        }\n        \"productive\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF0C1D3A), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFE0F2FE), Color(0xFFEADDFF)))\n            }\n        }\n        \"bored\" -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF1E2024), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFF1F5F9), Color(0xFFEADDFF)))\n            }\n        }\n        else -> {\n            if (isDark) {\n                Brush.verticalGradient(listOf(Color(0xFF1D1B30), Color(0xFF13101E)))\n            } else {\n                Brush.verticalGradient(listOf(Color(0xFFF3EDF7), Color(0xFFEADDFF)))\n            }\n        }\n    }\n}"
