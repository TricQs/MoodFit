    source: CORTEX_STEP_SOURCE_USER_EXPLICIT
  }
  user_input {
    user_response: "Build a simple, beautiful Android app named \"MoodFit\" that recommends activities based on user mood using Gemini AI.\n\nFeatures:\n1. A Dropdown Menu or Radio Buttons with options: Happy, Stressed, Tired, Productive, Bored.\n2. A \"Get Recommendations\" Button.\n3. A beautiful, dynamic background color that changes based on the selected mood.\n4. An output area showing 3 personalized activities generated by the AI.\n5. Save favorite activities to a local database for quick future access.\n6. Enable social sharing for users to post their suggested activities.\n7. A light and dark mode toggle for better accessibility.\n8. Integration with Google Calendar to schedule selected activities easily.\n9. Push notifications to remind users to take wellness breaks.\n10. User authentication via OAuth for secure data synchronization.\n11. Offline support to ensure core features remain usable without internet access.\n12. Social sharing features to invite friends to group wellness events.\n13. Data export options for personal wellness reports and insights.\n14. Dark mode for improved visibility during evening sessions.\n15. Push notifications to provide daily progress summaries.\n16. Multi-language support to reach a global user base.\n17. A secure biometric login for added user privacy.\n18. Real-time sync across all connected devices.\n19. Integration with popular health and fitness tracking hardware.\n20. A user-friendly dashboard for viewing long-term analytics.\n21. Offline mode functionality for uninterrupted data access during travel.\n22. Custom notification settings to keep users engaged and informed."
    items {
      item {
        text_block {
          content: "---\ntype: \"feature\"\ntitle: \"Build an Android app\"\nicon: \"android_color\"\n---\n\n"
        }
      }
    }
    items {
      text: "Build a simple, beautiful Android app named \"MoodFit\" that recommends activities based on user mood using Gemini AI.\n\nFeatures:\n1. A Dropdown Menu or Radio Buttons with options: Happy, Stressed, Tired, Productive, Bored.\n2. A \"Get Recommendations\" Button.\n3. A beautiful, dynamic background color that changes based on the selected mood.\n4. An output area showing 3 personalized activities generated by the AI.\n5. Save favorite activities to a local database for quick future access.\n6. Enable social sharing for users to post their suggested activities.\n7. A light and dark mode toggle for better accessibility.\n8. Integration with Google Calendar to schedule selected activities easily.\n9. Push notifications to remind users to take wellness breaks.\n10. User authentication via OAuth for secure data synchronization.\n11. Offline support to ensure core features remain usable without internet access.\n12. Social sharing features to invite friends to group wellness events.\n13. Data export options for personal wellness reports and insights.\n14. Dark mode for improved visibility during evening sessions.\n15. Push notifications to provide daily progress summaries.\n16. Multi-language support to reach a global user base.\n17. A secure biometric login for added user privacy.\n18. Real-time sync across all connected devices.\n19. Integration with popular health and fitness tracking hardware.\n20. A user-friendly dashboard for viewing long-term analytics.\n21. Offline mode functionality for uninterrupted data access during travel.\n22. Custom notification settings to keep users engaged and informed."
    }
  }
}
