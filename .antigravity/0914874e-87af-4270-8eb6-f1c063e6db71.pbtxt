      target_content: "@Composable\nfun ActivitySuggestionCard(\n    activity: ActivitySuggestion,\n    isDark: Boolean,\n    accentColor: Color,\n    onSaveToggle: () -> Unit,\n    onCalendarClick: () -> Unit,\n    onShareClick: () -> Unit\n) {\n    ElevatedCard(\n        modifier = Modifier\n            .fillMaxWidth()\n            .testTag(\"activity_card_${activity.title.replace(\" \", \"_\")}\"),\n        colors = CardDefaults.cardColors(\n            containerColor = if (isDark) Color(0xFF1E293B) else Color.White\n        ),\n        shape = RoundedCornerShape(16.dp)\n    ) {\n        Column(modifier = Modifier.padding(16.dp)) {\n            Row(\n                modifier = Modifier.fillMaxWidth(),\n                horizontalArrangement = Arrangement.SpaceBetween,\n                verticalAlignment = Alignment.Top\n            ) {\n                Column(modifier = Modifier.weight(1f)) {\n                    Text(\n                        text = activity.title,\n                        fontWeight = FontWeight.Bold,\n                        fontSize = 18.sp,\n                        color = if (isDark) Color.White else Color(0xFF1F2937)\n                    )\n                    Spacer(modifier = Modifier.height(6.dp))\n                    Row(horizontalArrangement = Arrangement.spacedBy(6.dp)) {\n                        Text(\n                            text = activity.type,\n                            color = accentColor,\n                            fontSize = 11.sp,\n                            fontWeight = FontWeight.Bold,\n                            modifier = Modifier\n                                .background(accentColor.copy(alpha = 0.15f), RoundedCornerShape(4.dp))\n                                .padding(horizontal = 6.dp, vertical = 2.dp)\n                        )\n                        Text(\n                            text = activity.category,\n                            color = Color(0xFF3B82F6),\n                            fontSize = 11.sp,\n                            fontWeight = FontWeight.Bold,\n                            modifier = Modifier\n                                .background(Color(0xFF3B82F6).copy(alpha = 0.1f), RoundedCornerShape(4.dp))\n                                .padding(horizontal = 6.dp, vertical = 2.dp)\n                        )\n                    }\n                }\n\n                Row(verticalAlignment = Alignment.CenterVertically) {\n                    Icon(\n                        imageVector = Icons.Default.Info,\n                        contentDescription = \"Duration Icon\",\n                        tint = Color.Gray,\n                        modifier = Modifier.size(16.dp)\n                    )\n                    Spacer(modifier = Modifier.width(4.dp))\n                    Text(\n                        text = activity.duration,\n                        fontSize = 12.sp,\n                        color = Color.Gray,\n                        fontWeight = FontWeight.Medium\n                    )\n                }\n            }\n\n            Spacer(modifier = Modifier.height(12.dp))\n            Text(\n                text = activity.description,\n                fontSize = 14.sp,\n                color = if (isDark) Color.LightGray else Color.DarkGray,\n                lineHeight = 20.sp\n            )\n\n            Spacer(modifier = Modifier.height(16.dp))\n\n            // Action Row: Save, Share, Google Calendar\n            Row(\n                modifier = Modifier.fillMaxWidth(),\n                horizontalArrangement = Arrangement.SpaceBetween,\n                verticalAlignment = Alignment.CenterVertically\n            ) {\n                // Database save toggle action\n                IconButton(\n                    onClick = onSaveToggle,\n                    modifier = Modifier.testTag(\"action_save_${activity.title.replace(\" \", \"_\")}\")\n                ) {\n                    Icon(\n                        imageVector = if (activity.isSaved) Icons.Default.Favorite else Icons.Default.FavoriteBorder,\n                        contentDescription = \"Save Action\",\n                        tint = if (activity.isSaved) Color.Red else Color.Gray\n                    )\n                }\n\n                // Add to calendar action\n                Button(\n                    onClick = onCalendarClick,\n                    colors = ButtonDefaults.buttonColors(\n                        containerColor = Color(0xFF10B981),\n                        contentColor = Color.White\n                    ),\n                    shape = RoundedCornerShape(8.dp),\n                    modifier = Modifier.testTag(\"action_calendar_${activity.title.replace(\" \", \"_\")}\")\n                ) {\n                    Icon(\n                        imageVector = Icons.Default.DateRange,\n                        contentDescription = \"Calendar Icon\",\n                        modifier = Modifier.size(16.dp)\n                    )\n                    Spacer(modifier = Modifier.width(6.dp))\n                    Text(\"Schedule\", fontSize = 12.sp, fontWeight = FontWeight.Bold)\n                }\n\n                // Share activity Action\n                IconButton(\n                    onClick = onShareClick,\n                    modifier = Modifier.testTag(\"action_share_${activity.title.replace(\" \", \"_\")}\")\n                ) {\n                    Icon(\n                        imageVector = Icons.Default.Share,\n                        contentDescription = \"Share\",\n                        tint = MaterialTheme.colorScheme.primary\n                    )\n                }\n            }\n        }\n    }\n}"
      replacement_content: "@Composable\nfun ActivitySuggestionCard(\n    activity: ActivitySuggestion,\n    isDark: Boolean,\n    accentColor: Color,\n    onSaveToggle: () -> Unit,\n    onCalendarClick: () -> Unit,\n    onShareClick: () -> Unit\n) {\n    // Dynamic Emoji detection based on category or title or keywords\n    val emoji = when {\n        activity.title.lowercase().contains(\"breath\") || activity.title.lowercase().contains(\"medit\") || activity.title.lowercase().contains(\"mind\") || activity.description.lowercase().contains(\"breath\") -> \"\360\237\247\230\"\n        activity.title.lowercase().contains(\"music\") || activity.title.lowercase().contains(\"sound\") || activity.title.lowercase().contains(\"beat\") || activity.title.lowercase().contains(\"lo-fi\") || activity.title.lowercase().contains(\"audio\") || activity.description.lowercase().contains(\"audio\") -> \"\360\237\216\247\"\n        activity.title.lowercase().contains(\"journal\") || activity.title.lowercase().contains(\"write\") || activity.title.lowercase().contains(\"note\") || activity.title.lowercase().contains(\"gratitude\") || activity.description.lowercase().contains(\"write\") -> \"\360\237\223\235\"\n        activity.title.lowercase().contains(\"walk\") || activity.title.lowercase().contains(\"stretch\") || activity.title.lowercase().contains(\"run\") || activity.title.lowercase().contains(\"mov\") -> \"\360\237\232\266\"\n        else -> \"\342\234\250\"\n    }\n\n    // Dynamic background for emoji block matching mockup exactly\n    val pastelBg = when (emoji) {\n        \"\360\237\247\230\" -> if (isDark) Color(0xFF623B4C) else Color(0xFFFFD8E4) // Pastel Pink\n        \"\360\237\216\247\" -> if (isDark) Color(0xFF2E243D) else Color(0xFFE8DEF8) // Soft Lilac\n        \"\360\237\223\235\" -> if (isDark) Color(0xFF1E3A54) else Color(0xFFD0BCFF) // Pastel Purple\n        \"\360\237\232\266\" -> if (isDark) Color(0xFF1C321C) else Color(0xFFE2F9EE) // Soft Mint\n        else -> if (isDark) Color(0xFF2E243D) else Color(0xFFE8DEF8)\n    }\n\n    Card(\n        modifier = Modifier\n            .fillMaxWidth()\n            .testTag(\"activity_card_${activity.title.replace(\" \", \"_\")}\"),\n        colors = CardDefaults.cardColors(\n            containerColor = if (isDark) Color(0xFF1E1B30).copy(alpha = 0.85f) else Color.White.copy(alpha = 0.82f)\n        ),\n        shape = RoundedCornerShape(20.dp),\n        border = androidx.compose.foundation.BorderStroke(\n            width = 1.dp,\n            color = if (isDark) Color.White.copy(alpha = 0.1f) else Color(0xFFCAC4D0).copy(alpha = 0.5f)\n        )\n    ) {\n        Column(modifier = Modifier.padding(14.dp)) {\n            // Row matching mockup layout\n            Row(\n                modifier = Modifier.fillMaxWidth(),\n                verticalAlignment = Alignment.CenterVertically\n            ) {\n                // Left: Emoji illustration block\n                Box(\n                    modifier = Modifier\n                        .size(44.dp)\n                        .clip(RoundedCornerShape(12.dp))\n                        .background(pastelBg),\n                    contentAlignment = Alignment.Center\n                ) {\n                    Text(text = emoji, fontSize = 20.sp)\n                }\n\n                Spacer(modifier = Modifier.width(12.dp))\n\n                // Middle: Text Area\n                Column(modifier = Modifier.weight(1f)) {\n                    Row(\n                        verticalAlignment = Alignment.CenterVertically,\n                        horizontalArrangement = Arrangement.spacedBy(6.dp)\n                    ) {\n                        Text(\n                            text = activity.title,\n                            fontWeight = FontWeight.Bold,\n                            fontSize = 14.sp,\n                            color = if (isDark) Color.White else Color(0xFF1D1B20),\n                            maxLines = 1,\n                            overflow = TextOverflow.Ellipsis\n                        )\n                        Box(\n                            modifier = Modifier\n                                .background(accentColor.copy(alpha = 0.15f), RoundedCornerShape(4.dp))\n                                .padding(horizontal = 4.dp, vertical = 2.dp)\n                        ) {\n                            Text(\n                                text = activity.duration,\n                                fontSize = 9.sp,\n                                fontWeight = FontWeight.Bold,\n                                color = accentColor\n                            )\n                        }\n                    }\n                    Spacer(modifier = Modifier.height(2.dp))\n                    Text(\n                        text = activity.description,\n                        fontSize = 11.sp,\n                        color = if (isDark) Color.LightGray else Color(0xFF49454F),\n                        lineHeight = 15.sp,\n                        maxLines = 2,\n                        overflow = TextOverflow.Ellipsis\n                    )\n                }\n\n                Spacer(modifier = Modifier.width(4.dp))\n\n                // Right: Premium Heart Action Icon matching mockup (\342\231\245 vs \342\231\241)\n                IconButton(\n                    onClick = onSaveToggle,\n                    modifier = Modifier\n                        .size(36.dp)\n                        .testTag(\"action_save_${activity.title.replace(\" \", \"_\")}\")\n                ) {\n                    Text(\n                        text = if (activity.isSaved) \"\342\231\245\357\270\217\" else \"\342\231\241\",\n                        fontSize = 20.sp,\n                        color = if (activity.isSaved) Color.Red else Color.Gray\n                    )\n                }\n            }\n\n            Spacer(modifier = Modifier.height(8.dp))\n\n            // Footer Section: Badges & Sub-actions (Schedule and Share)\n            Row(\n                modifier = Modifier.fillMaxWidth(),\n                verticalAlignment = Alignment.CenterVertically,\n                horizontalArrangement = Arrangement.SpaceBetween\n            ) {\n                // Secondary Badge tags\n                Row(horizontalArrangement = Arrangement.spacedBy(4.dp)) {\n                    Text(\n                        text = activity.type,\n                        fontSize = 9.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = if (isDark) Color(0xFFE8DEF8) else Color(0xFF6750A4),\n                        modifier = Modifier\n                            .background(if (isDark) Color(0xFF2C1E4D) else Color(0xFFE8DEF8), RoundedCornerShape(6.dp))\n                            .padding(horizontal = 6.dp, vertical = 3.dp)\n                    )\n                    Text(\n                        text = activity.category,\n                        fontSize = 9.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = Color(0xFF0284C7),\n                        modifier = Modifier\n                            .background(if (isDark) Color(0xFF0F3147) else Color(0xFFE0F2FE), RoundedCornerShape(6.dp))\n                            .padding(horizontal = 6.dp, vertical = 3.dp)\n                    )\n                }\n\n                // Action buttons: Schedule & Share\n                Row(\n                    verticalAlignment = Alignment.CenterVertically,\n                    horizontalArrangement = Arrangement.spacedBy(6.dp)\n                ) {\n                    // Schedule button\n                    Button(\n                        onClick = onCalendarClick,\n                        colors = ButtonDefaults.buttonColors(\n                            containerColor = if (isDark) Color(0xFF34D399).copy(alpha = 0.2f) else Color(0xFF10B981).copy(alpha = 0.15f),\n                            contentColor = if (isDark) Color(0xFF34D399) else Color(0xFF047857)\n                        ),\n                        shape = RoundedCornerShape(8.dp),\n                        contentPadding = androidx.compose.foundation.layout.PaddingValues(horizontal = 10.dp, vertical = 2.dp),\n                        modifier = Modifier\n                            .height(28.dp)\n                            .testTag(\"action_calendar_${activity.title.replace(\" \", \"_\")}\")\n                    ) {\n                        Text(\"Add Calendar\", fontSize = 10.sp, fontWeight = FontWeight.Bold)\n                    }\n\n                    // Share button\n                    Box(\n                        modifier = Modifier\n                            .size(28.dp)\n                            .clip(RoundedCornerShape(8.dp))\n                            .background(if (isDark) Color.White.copy(alpha = 0.08f) else Color.White.copy(alpha = 0.6f))\n                            .clickable { onShareClick() }\n                            .testTag(\"action_share_${activity.title.replace(\" \", \"_\")}\"),\n                        contentAlignment = Alignment.Center\n                    ) {\n                        Icon(\n                            imageVector = Icons.Default.Share,\n                            contentDescription = \"Share item\",\n                            tint = if (isDark) Color.White else Color(0xFF6750A4),\n                            modifier = Modifier.size(13.dp)\n                        )\n                    }\n                }\n            }\n        }\n    }\n}"
    }
