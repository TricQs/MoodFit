          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"stressed\" -> Color(0xFF10B981)    // Soothing Emerald Teal"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"tired\" -> Color(0xFF6366F1)       // Twilight Indigo"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        \"productive\" -> Color(0xFF3B82F6)  // Neon Cobalt Blue"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
