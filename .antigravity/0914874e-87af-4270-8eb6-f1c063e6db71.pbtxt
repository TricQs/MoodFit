      target_content: "            NavigationBar(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .windowInsetsPadding(WindowInsets.navigationBars)\n                    .testTag(\"navigation_menu\"),\n                tonalElevation = 8.dp\n            ) {\n                NavigationBarItem(\n                    selected = activeTab == \"explore\",\n                    onClick = { activeTab = \"explore\" },\n                    icon = { Icon(Icons.Default.Home, contentDescription = \"Explore\") },\n                    label = { Text(viewModel.t(\"Generate\")) },\n                    modifier = Modifier.testTag(\"nav_explore\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"favorites\",\n                    onClick = { activeTab = \"favorites\" },\n                    icon = { Icon(Icons.Default.Favorite, contentDescription = \"Favorites\") },\n                    label = { Text(viewModel.t(\"Favorites\")) },\n                    modifier = Modifier.testTag(\"nav_favorites\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"analytics\",\n                    onClick = { activeTab = \"analytics\" },\n                    icon = { Icon(Icons.Default.PlayArrow, contentDescription = \"Analytics\") },\n                    label = { Text(viewModel.t(\"Active Checks\")) },\n                    modifier = Modifier.testTag(\"nav_analytics\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"settings\",\n                    onClick = { activeTab = \"settings\" },\n                    icon = { Icon(Icons.Default.Settings, contentDescription = \"Settings\") },\n                    label = { Text(viewModel.t(\"Language\")) },\n                    modifier = Modifier.testTag(\"nav_settings\")\n                )\n            }"
      replacement_content: "            NavigationBar(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .windowInsetsPadding(WindowInsets.navigationBars)\n                    .testTag(\"navigation_menu\"),\n                tonalElevation = 8.dp,\n                containerColor = if (isDarkMode.value) Color(0xFF1D1B30) else Color(0xFFF3EDF7)\n            ) {\n                val navBarItemColors = NavigationBarItemDefaults.colors(\n                    selectedIconColor = if (isDarkMode.value) Color.White else Color(0xFF1D1B20),\n                    unselectedIconColor = if (isDarkMode.value) Color.Gray else Color(0xFF49454F),\n                    selectedTextColor = if (isDarkMode.value) Color.White else Color(0xFF1D1B20),\n                    unselectedTextColor = if (isDarkMode.value) Color.Gray else Color(0xFF49454F),\n                    indicatorColor = if (isDarkMode.value) Color(0xFF49454F) else Color(0xFFE8DEF8)\n                )\n\n                NavigationBarItem(\n                    selected = activeTab == \"explore\",\n                    onClick = { activeTab = \"explore\" },\n                    icon = { Icon(Icons.Default.Home, contentDescription = \"Explore\") },\n                    label = { Text(viewModel.t(\"Generate\")) },\n                    colors = navBarItemColors,\n                    modifier = Modifier.testTag(\"nav_explore\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"favorites\",\n                    onClick = { activeTab = \"favorites\" },\n                    icon = { Icon(Icons.Default.Favorite, contentDescription = \"Favorites\") },\n                    label = { Text(viewModel.t(\"Favorites\")) },\n                    colors = navBarItemColors,\n                    modifier = Modifier.testTag(\"nav_favorites\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"analytics\",\n                    onClick = { activeTab = \"analytics\" },\n                    icon = { Icon(Icons.Default.PlayArrow, contentDescription = \"Analytics\") },\n                    label = { Text(viewModel.t(\"Active Checks\")) },\n                    colors = navBarItemColors,\n                    modifier = Modifier.testTag(\"nav_analytics\")\n                )\n                NavigationBarItem(\n                    selected = activeTab == \"settings\",\n                    onClick = { activeTab = \"settings\" },\n                    icon = { Icon(Icons.Default.Settings, contentDescription = \"Settings\") },\n                    label = { Text(viewModel.t(\"Language\")) },\n                    colors = navBarItemColors,\n                    modifier = Modifier.testTag(\"nav_settings\")\n                )\n            }"
    }
