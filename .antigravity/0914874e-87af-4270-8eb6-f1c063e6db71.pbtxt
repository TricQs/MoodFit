    replacement_chunks {
      target_content: "            // High level App Status Banner\n            Row(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .padding(horizontal = 16.dp, vertical = 12.dp),\n                verticalAlignment = Alignment.CenterVertically,\n                horizontalArrangement = Arrangement.SpaceBetween\n            ) {\n                Column {\n                    Text(\n                        text = \"MoodFit\",\n                        fontSize = 28.sp,\n                        fontWeight = FontWeight.ExtraBold,\n                        color = if (isDarkMode.value) Color.White else Color(0xFF1E1B4B),\n                        modifier = Modifier.testTag(\"app_title\")\n                    )\n                    Text(\n                        text = viewModel.t(\"Unlocking daily wellness potential\"),\n                        fontSize = 12.sp,\n                        color = if (isDarkMode.value) Color.White.copy(alpha = 0.7f) else Color.DarkGray\n                    )\n                }\n\n                // Header Badges Row\n                Row(verticalAlignment = Alignment.CenterVertically) {\n                    if (authState) {\n                        Icon(\n                            imageVector = Icons.Default.CheckCircle,\n                            contentDescription = \"Synced Profile\",\n                            tint = Color(0xFF10B981),\n                            modifier = Modifier\n                                .size(24.dp)\n                                .clickable {\n                                    Toast\n                                        .makeText(\n                                            context,\n                                            viewModel.t(\"Secure Data Synced\") + \": $emailState\",\n                                            Toast.LENGTH_SHORT\n                                        )\n                                        .show()\n                                }\n                        )\n                    } else {\n                        IconButton(onClick = { activeTab = \"settings\" }) {\n                            Icon(\n                                imageVector = Icons.Default.AccountCircle,\n                                contentDescription = \"Unsigned Profile\",\n                                tint = if (isDarkMode.value) Color.White.copy(alpha = 0.6f) else Color.LightGray\n                            )\n                        }\n                    }\n\n                    if (deviceState != \"None\") {\n                        Spacer(modifier = Modifier.width(4.dp))\n                        Icon(\n                            imageVector = Icons.Default.Star,\n                            contentDescription = \"Wearable connected\",\n                            tint = Color(0xFFFBBF24),\n                            modifier = Modifier.size(20.dp)\n                        )\n                    }\n\n                    Spacer(modifier = Modifier.width(8.dp))\n                    IconButton(\n                        onClick = { isDarkMode.value = !isDarkMode.value },\n                        modifier = Modifier.testTag(\"theme_switch_toggle\")\n                    ) {\n                        Icon(\n                            imageVector = if (isDarkMode.value) Icons.Default.Refresh else Icons.Default.Notifications,\n                            contentDescription = \"Toggle Theme Visuals\",\n                            tint = if (isDarkMode.value) Color.Yellow else Color.DarkGray\n                        )\n                    }\n                }\n            }"
      replacement_content: "            // High level App Status Banner matching Vibrant Palette Layout\n            Row(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .padding(horizontal = 16.dp, vertical = 16.dp),\n                verticalAlignment = Alignment.CenterVertically,\n                horizontalArrangement = Arrangement.SpaceBetween\n            ) {\n                Column {\n                    Text(\n                        text = viewModel.t(\"Welcome back\").uppercase(),\n                        fontSize = 11.sp,\n                        fontWeight = FontWeight.Bold,\n                        letterSpacing = 1.2.sp,\n                        color = if (isDarkMode.value) Color(0xFFCCC2DC) else Color(0xFF49454F)\n                    )\n                    Spacer(modifier = Modifier.height(2.dp))\n                    Text(\n                        text = \"MoodFit\",\n                        fontSize = 26.sp,\n                        fontWeight = FontWeight.Black,\n                        color = if (isDarkMode.value) Color.White else Color(0xFF1D1B20),\n                        modifier = Modifier.testTag(\"app_title\")\n                    )\n                }\n\n                // Header Badges Row\n                Row(\n                    verticalAlignment = Alignment.CenterVertically,\n                    horizontalArrangement = Arrangement.spacedBy(8.dp)\n                ) {\n                    if (deviceState != \"None\") {\n                        Icon(\n                            imageVector = Icons.Default.Star,\n                            contentDescription = \"Wearable connected\",\n                            tint = Color(0xFFFBBF24),\n                            modifier = Modifier.size(20.dp)\n                        )\n                    }\n\n                    // Dynamic Theme Circle Toggle matching spec exactly (\360\237\214\231 / \342\230\200\357\270\217)\n                    Box(\n                        modifier = Modifier\n                            .size(40.dp)\n                            .clip(CircleShape)\n                            .background(if (isDarkMode.value) Color(0xFF49454F) else Color(0xFF6750A4))\n                            .clickable { isDarkMode.value = !isDarkMode.value }\n                            .testTag(\"theme_switch_toggle\"),\n                        contentAlignment = Alignment.Center\n                    ) {\n                        Text(\n                            text = if (isDarkMode.value) \"\342\230\200\357\270\217\" else \"\360\237\214\231\",\n                            fontSize = 18.sp\n                        )\n                    }\n\n                    // Profile Action Badge matching spec exactly (\360\237\221\244)\n                    Box(\n                        modifier = Modifier\n                            .size(40.dp)\n                            .clip(CircleShape)\n                            .background(if (isDarkMode.value) Color(0xFF49454F) else Color(0xFF6750A4))\n                            .clickable { activeTab = \"settings\" }\n                            .testTag(\"profile_quick_nav\"),\n                        contentAlignment = Alignment.Center\n                    ) {\n                        Text(\n                            text = if (authState) \"\342\234\205\" else \"\360\237\221\244\",\n                            fontSize = 16.sp\n                        )\n                    }\n                }\n            }"
    }
