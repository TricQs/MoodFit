        lines {
          text: "                Intent.EXTRA_TEXT,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                \"Hey! I am check-in on MoodFit and going to practice this activity to build state:\\n\\n\342\234\250 *$title* \342\234\250\\n$description\\n\342\217\261 *Vibe duration:* $duration\\n\\nInvite you to secure wellness breaks. Empowered by MoodFit! \342\231\245\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
