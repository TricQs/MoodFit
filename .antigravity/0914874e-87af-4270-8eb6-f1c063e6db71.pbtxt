        lines {
          text: "fun scheduleGoogleCalendarEvent(context: Context, title: String, description: String, duration: String) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    try {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        val intent = Intent(Intent.ACTION_INSERT).apply {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            data = CalendarContract.Events.CONTENT_URI"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            putExtra(CalendarContract.Events.TITLE, \"MoodFit Routine: $title\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            putExtra(CalendarContract.Events.DESCRIPTION, \"$description\\n\\nDuration recommendation: $duration\\nUplifted with MoodFit.\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            putExtra(CalendarContract.Events.EVENT_LOCATION, \"Home Wellness Sanctuary\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            putExtra(CalendarContract.EXTRA_EVENT_BEGIN_TIME, System.currentTimeMillis() + 10 * 60 * 1000) // starts in 10 mins"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            putExtra(CalendarContract.EXTRA_EVENT_END_TIME, System.currentTimeMillis() + 40 * 60 * 1000)   // 30 min event"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        context.startActivity(intent)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } catch (e: Exception) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        Toast.makeText(context, \"Could not open system Calendar organizer.\", Toast.LENGTH_SHORT).show()"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
