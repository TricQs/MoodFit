        lines {
          text: "        .setSmallIcon(android.R.drawable.ic_lock_idle_alarm)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .setContentTitle(title)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
