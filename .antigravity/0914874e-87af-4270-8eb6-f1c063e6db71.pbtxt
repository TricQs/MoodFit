        lines {
          text: "fun sendLocalNotification(context: Context, title: String, message: String) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    val channelId = \"moodfit_reminders_channel\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    val notificationManager = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        val channel = NotificationChannel("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            channelId,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            \"MoodFit Wellness Alerts\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            NotificationManager.IMPORTANCE_DEFAULT"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ).apply {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            description = \"Fires timely break notifications to prevent strain\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        notificationManager.createNotificationChannel(channel)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
